POSTGRES_DB=sisflow
POSTGRES_USER=sisflow
POSTGRES_PASSWORD=sisflow
POSTGRES_PORT=5432

SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/sisflow
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=sisflow

REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

TICKET_SERVICE_PORT=8080
AUTH_SERVICE_PORT=8081
NOTIFICATION_SERVICE_PORT=8082

JWT_SECRET=change-me
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_DAYS=30

APP_BASE_URL=http://localhost:5173
APP_BASE_DOMAIN=localhost
APP_TRUST_HOST_HEADER=false
EMAIL_CONFIRMATION_EXPIRATION_HOURS=24
SWAGGER_ENABLED=true

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGIN_PATTERNS=http://*.localhost:8080
FILE_UPLOAD_BASE_DIR=./uploads
FILE_DOWNLOAD_TOKEN_TTL_SECONDS=60
FILE_DOWNLOAD_TOKEN_ISSUE_LIMIT_PER_MINUTE=60
FILE_DOWNLOAD_TOKEN_RESOLVE_LIMIT_PER_MINUTE=180
FILE_ACCEL_REDIRECT_PREFIX=/_protected_files

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

SPRING_CACHE_REDIS_TIME_TO_LIVE=10m
SPRING_DATA_REDIS_TIMEOUT=2s
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

SECURITY_LOGIN_MAX_ATTEMPTS=10
SECURITY_LOGIN_IP_MAX_ATTEMPTS=50
SECURITY_LOGIN_RATE_LIMIT_CAPACITY=30
SECURITY_LOGIN_RATE_LIMIT_WINDOW_MINUTES=1
SECURITY_LOGIN_LOCKOUT_DURATION_MINUTES=15
SECURITY_API_RATE_LIMIT_ENABLED=true
SECURITY_API_RATE_LIMIT_USER_READ_CLIENT=600
SECURITY_API_RATE_LIMIT_USER_WRITE_CLIENT=120
SECURITY_API_RATE_LIMIT_USER_READ_DEVELOPER=900
SECURITY_API_RATE_LIMIT_USER_WRITE_DEVELOPER=180
SECURITY_API_RATE_LIMIT_USER_READ_MODERATOR=1200
SECURITY_API_RATE_LIMIT_USER_WRITE_MODERATOR=240
SECURITY_API_RATE_LIMIT_USER_READ_ADMIN=1800
SECURITY_API_RATE_LIMIT_USER_WRITE_ADMIN=360
SECURITY_API_RATE_LIMIT_TENANT_READ=3000
SECURITY_API_RATE_LIMIT_TENANT_WRITE=900
SECURITY_API_RATE_LIMIT_API_KEY_READ=1200
SECURITY_API_RATE_LIMIT_API_KEY_WRITE=300

NOTIFICATIONS_EXCHANGE=sisflow.notifications
NOTIFICATIONS_EMAIL_QUEUE=notification.email.auth
NOTIFICATIONS_EMAIL_ROUTING_KEY=email.auth
